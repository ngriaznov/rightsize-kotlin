# EditorConfig: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
indent_size = 4
# The ktlint/kotlin default: continuation lines get one extra indent level.
continuation_indent_size = 4
max_line_length = 120

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[gradlew]
end_of_line = lf

[gradlew.bat]
end_of_line = crlf
